{
	"proxy": "",
	"context_servers": {
		"postgres-context-server": {
			"enabled": true,
			"remote": false,
			"settings": {
				"database_url": "postgresql://admin:admin@localhost:5432/dorlab"
			}
		}
	},
	"terminal": {
		"font_weight": 400.0
	},
	"cli_default_open_behavior": "new_window",
	"show_edit_predictions": false,
	"agent_servers": {
		"opencode": {
			"type": "registry"
		},
		"codex-acp": {
			"type": "registry"
		}
	},
	"edit_predictions": {
		"provider": "copilot",
		"copilot": {
			"enable_next_edit_suggestions": false
		},
		"mode": "subtle"
	},
	"outline_panel": {
		"dock": "left"
	},
	"collaboration_panel": {
		"dock": "left"
	},
	"git_panel": {
		"dock": "left"
	},
	"text_rendering_mode": "platform_default",
	"relative_line_numbers": "enabled",
	"diagnostics": {
		"inline": {
			"enabled": true
		}
	},
	"git": {
		"inline_blame": {
			"enabled": false
		}
	},
	"toolbar": {
		"breadcrumbs": true,
		"quick_actions": false
	},
	"scrollbar": {
		"show": "never"
	},
	"telemetry": {
		"diagnostics": true,
		"metrics": false
	},
	"vim_mode": true,
	"project_panel": {
		"hide_root": false,
		"scrollbar": {
			"show": "auto"
		},
		"folder_icons": true,
		"dock": "right",
		"auto_fold_dirs": false
	},
	"agent": {
		"flexible": false,
		"single_file_review": true,
		"enable_feedback": true,
		"dock": "left",
		"enabled": true,
		"button": true,
		"model_parameters": []
	},
	"minimap": {
		"show": "never"
	},
	"buffer_font_fallbacks": ["Droid Sans Mono", "monospace", "monospace"],
	"buffer_font_family": "JetBrainsMono Nerd Font",
	"file_types": {
		"css": ["*.css"]
	},
	"auto_indent_on_paste": true,
	"hard_tabs": true,
	"tab_size": 2,
	"icon_theme": {
		"mode": "light",
		"light": "Material Icon Theme",
		"dark": "Material Icon Theme"
	},
	"base_keymap": "VSCode",
	"ui_font_size": 18,
	"agent_buffer_font_size": 15,
	"buffer_font_size": 15,
	"theme": {
		"mode": "light",
		"light": "Catppuccin Mocha - No Italics",
		"dark": "Islands Dark"
	},

	"lsp": {
		"discord_presence": {
			"initialization_options": {
				"details": null
			}
		}
	}
}
