{
  "window.restoreWindows": "all",
  "files.hotExit": "onExit",
  "extensions.ignoreRecommendations": true,
  "files.associations": {
    "*.pl": "prolog"
  },
  "editor.suggestSelection": "first",
  "editor.fontSize": 15,
  "editor.fontFamily": "MesloLGS NF, SFMono Nerd Font, monospace",
  "workbench.colorTheme": "Tokyo Night",
  "workbench.productIconTheme": "icons-carbon",
  "workbench.colorCustomizations": {
    "list.activeSelectionBackground": "#0D181C",
    "list.hoverBackground": "#0D181C",
    "editorWidget.background": "#000A0E",
    "editorWidget.": "#000A0E",
    "editorWidget.resizeBorder": "#000A0E",
    "panel.background": "#000A0E",
    "panel.border": "#000a0e00",
    "titleBar.activeBackground": "#000A0E",
    "titleBar.border": "#000a0e00",
    "breadcrumbPicker.background": "#0D181C",
    "settings.dropdownBackground": "#0D181C",
    "settings.numberInputBackground": "#0D181C",
    "settings.textInputBackground": "#0D181C",
    "settings.checkboxBackground": "#0D181C",
    "editor.background": "#061115",
    "tab.activeBackground": "#000A0E",
    "tab.inactiveBackground": "#061115",
    "sideBar.background": "#000A0E",
    "sideBar.border": "#ff000000",
    "sideBarSectionHeader.background": "#000A0E",
    "activityBar.background": "#000A0E",
    "activityBar.border": "#000a0e00",
    "statusBar.background": "#000A0E",
    "statusBar.border": "#000a0e00",
    "scrollbarSlider.activeBackground": "#000a0ee7",
    "scrollbarSlider.background": "#000a0ee7",
    "tab.activeBorder": "#06111500",
    "editorGroupHeader.tabsBackground": "#000A0E",
    "editorGroupHeader.border": "#00bbff00",
    "editorGroupHeader.tabsBorder": "#06111500",
    "statusBar.noFolderBackground": "#061115",
    "tab.border": "#06111500",
    "editorHoverWidget.background": "#000a0e",
    "editorHoverWidget.border": "#000a0e00",
    "menu.background": "#061115",
    "debugToolBar.background": "#061115",
    "editorBracketMatch.background": "#061115",
    "quickInput.background": "#061115",
    "editorOverviewRuler.border": "#06111500",
    "notifications.background": "#061115",
    "breadcrumb.background": "#000A0E",
    "terminal.background": "#000A0E",
    "editor.selectionBackground": "#658d9c81",
    "editor.lineHighlightBackground": "#000A0E",
  },
  "workbench.list.smoothScrolling": false,
  "editor.smoothScrolling": false,
  "customizeUI.activityBar": "bottom",
  "customizeUI.titleBar": "inline",
  "customizeUI.font.regular": "SF Pro Display",
  "customizeUI.fontSizeMap": {
    "13px": "12px",
    "monospace": "12px"
  },
  "customizeUI.stylesheet": {
    ".tabs-container ": "padding-top:7px; padding-left:2px; padding-bottom:5px",
    ".tabs-container > .tab": "border-radius: 7px 7px 7px 7px; height: 20px; margin-left: 5px; padding-right:4px",
    ".monaco-editor .suggest-widget": "border-radius: 10px 10px 10px 10px; overflow:hidden;"
  },
  "window.titleBarStyle": "custom",
  "editor.minimap.enabled": false,
  "window.menuBarVisibility": "toggle",
  "editor.formatOnSave": true,
  "glassit.alpha": 255,
  "files.autoSave": "afterDelay",
  "editor.tabSize": 2,
  "explorer.confirmDelete": false,
  "debug.onTaskErrors": "debugAnyway",
  "workbench.startupEditor": "none",
  "editor.linkedEditing": true,
  "explorer.confirmDragAndDrop": false,
  "workbench.tree.indent": 10,
  "workbench.tree.renderIndentGuides": "always",
  "git.confirmSync": false,
  "git.autofetch": true,
  "git.enableSmartCommit": true,
  "liveServer.settings.donotVerifyTags": true,
  "liveServer.settings.donotShowInfoMsg": true,
  "Lua.telemetry.enable": true,
  "editor.inlineSuggest.enabled": true,
  "github.copilot.enable": {
    "*": true,
    "yaml": false,
    "plaintext": false,
    "markdown": false
  }
}